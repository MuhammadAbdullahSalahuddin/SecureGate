
networks:
  guardian-net:
    driver: bridge


services:
  api:
    build: ./backend
    ports: ["4000:4000"]
    env_file: .env
    depends_on: [postgres, mongo, redis]
    networks: [guardian-net]

  ws-server:
    build: ./backend
    command: ["node", "dist/main.ws.js"]
    ports: ["3001:3001"]
    env_file: .env
    depends_on: [resdis, mongo]
    networks: [guardian-net]

  vault-service:
    build: ./vault-service
    env_file: .env
    networks: [guardian-net]

  postgres:
    image: postgres:16
    container_name: securegate_postgres
    environment:
      POSTGRES_USER: admin
      POSTGRES_PASSWORD: admin
      POSTGRES_DB: securegate

    volumes:
      - pgdata:/var/lib/postgresql/data
    networks: [guardian-net]

  mongo:
    image: mongo:latest
    environment:
      MONGO_INITDB_ROOT_USERNAME: admin
      MONGO_INITDB_ROOT_PASSWORD: admin
    volumes:
      - mongodata:/data/db
    networks: [guardian-net]

  redis:
    image: redis:7
    container_name: securegate_redis
    command: redis-server --requirepass admin
    networks: [guardian-net]

volumes:
  pgdata:
  mongodata:
